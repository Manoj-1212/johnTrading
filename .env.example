# EC2 ENVIRONMENT CONFIGURATION
# Source this file in your .bashrc or deploy scripts
# cp .env.example .env && source .env

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Project paths
export APP_HOME="/home/ubuntu/johntrading"
export APP_VENV="$APP_HOME/.venv"
export LOG_DIR="$APP_HOME/logs"
export DATA_DIR="$APP_HOME/phase1_data/cache"

# Python settings
export PYTHONUNBUFFERED=1
export PYTHONPATH="$APP_HOME"

# ============================================================================
# TRADING SYSTEM PARAMETERS
# ============================================================================

# Minimum signals required to generate BUY signal (out of 7)
export MIN_SIGNALS=5

# Risk management
export STOP_LOSS=0.07
export TAKE_PROFIT=0.15
export MAX_HOLDING_DAYS=20

# Capital and position sizing
export PAPER_CAPITAL=10000
export POSITION_SIZE_PCT=20

# ============================================================================
# EXECUTION SETTINGS
# ============================================================================

# Stock universe (comma-separated)
export TICKERS="AAPL,MSFT,NVDA,TSLA,AMZN"

# Benchmark to compare against
export BENCHMARK="VOO"

# Data settings
export START_DATE="2020-01-01"
export END_DATE="2024-12-31"

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
export LOG_LEVEL="INFO"

# Email notifications (optional)
export SEND_EMAIL="false"
export EMAIL_TO="your-email@example.com"
export SMTP_SERVER="smtp.gmail.com"

# CloudWatch (optional)
export CLOUDWATCH_ENABLED="false"
export AWS_REGION="us-east-1"

# ============================================================================
# AWS SETTINGS
# ============================================================================

# AWS credentials (use IAM roles instead of storing here!)
# export AWS_ACCESS_KEY_ID="your_key"
# export AWS_SECRET_ACCESS_KEY="your_secret"
export AWS_REGION="us-east-1"

# S3 bucket for backups
export BACKUP_BUCKET="john-trading-backups"
export BACKUP_ENABLED="false"

# ============================================================================
# REALISTIC BACKTEST OPTIONS
# ============================================================================

# Slippage in basis points (0.05% = 5bp)
export SLIPPAGE_BPS=5

# Commission per trade in basis points (0.1% = 10bp)
export COMMISSION_BPS=10

# Execution type: 'open' (next bar open) or 'close' (current close)
export EXECUTION_TYPE="open"

# ============================================================================
# DEPLOYMENT & SYSTEM
# ============================================================================

# Instance type
export INSTANCE_TYPE="m7i-flex.large"

# Instance ID (populated during deployment)
export EC2_INSTANCE_ID=""

# Deployment timestamp
export DEPLOYMENT_DATE=$(date -u +'%Y-%m-%d %H:%M:%S UTC')

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

# Load this config
load_config() {
    if [ -f "$HOME/.env" ]; then
        export $(cat "$HOME/.env" | grep -v '^#' | xargs)
        echo "✓ Config loaded from ~/.env"
    else
        echo "⚠ ~/.env not found"
    fi
}

# Activate virtual environment
activate_trading() {
    source "$APP_VENV/bin/activate"
    export PYTHONPATH="$APP_HOME"
    cd "$APP_HOME"
    echo "✓ Trading environment activated"
}

# Run trading system
run_trading() {
    activate_trading
    python run_all.py
}

# View logs
view_logs() {
    tail -f "$LOG_DIR/trading.log"
}

# Check system status
system_status() {
    echo "=== SYSTEM STATUS ==="
    echo "Python: $(python --version)"
    echo "venv: $APP_VENV"
    echo "Logs: $LOG_DIR"
    echo "Data: $DATA_DIR"
    echo "Disk: $(df -h $APP_HOME | tail -1)"
    echo "Memory: $(free -h | grep Mem)"
    ps aux | grep python | grep -v grep || echo "No trading processes running"
}

# Deploy systemd service
deploy_service() {
    echo "Installing systemd service..."
    sudo cp johntrading.service /etc/systemd/system/
    sudo systemctl daemon-reload
    sudo systemctl enable johntrading.service
    echo "✓ Service installed"
    echo "Run 'sudo systemctl start johntrading' to start"
}

# ============================================================================
